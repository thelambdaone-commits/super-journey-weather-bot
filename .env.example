# WeatherBot Configuration
# Copy this file to .env and fill in your API keys

# ===========================================
# TRADING MODES
# ===========================================
PAPER_MODE=true
SIGNAL_MODE=true
LIVE_TRADE=false
TUI_MODE=false
DASHBOARD_ENABLED=false

# ===========================================
# TRADING PARAMETERS
# ===========================================
BALANCE=10000.0
MAX_BET=20.0
MIN_EV=0.1
MAX_PRICE=0.45
MIN_VOLUME=500
MIN_HOURS=2.0
MAX_HOURS=72.0
KELLY_FRACTION=0.25
SCAN_INTERVAL=3600
CALIBRATION_MIN=30
MAX_SLIPPAGE=0.03
SIGNAL_MIN_EV=0.05
SIGNAL_MIN_PROB=0.75
SIGNAL_MIN_CONFIDENCE=0.75
SIGNAL_MAX_UNCERTAINTY=0.18
SIGNAL_RATE_LIMIT_HOUR=3
SIGNAL_CITY_COOLDOWN_HOURS=8
SIGNAL_DUPLICATE_WINDOW_HOURS=24
SIGNAL_MIN_PRICE_MOVE=0.02
SIGNAL_TOP_K=3

# ===========================================
# API KEYS (Remplir avec vos clés)
# ===========================================

# Telegram (notifications)
# Obtenir le token depuis @BotFather sur Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SIGNAL_CHAT_ID=

# Groq (analyses AI)
# Obtenir une clé gratuite: https://console.groq.com/
GROQ_API_KEY=

# Ouroboros notifications (optionnel)
# Mettre "true" pour activer les notifications Telegram
OUROBOROS_TELEGRAM_FEED=true

# ===========================================
# PATHS (optionnel)
# ===========================================
DATA_DIR=data
LOGS_DIR=logs