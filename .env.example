# WeatherBot Configuration
# Copy this file to .env and fill in your API keys

# Visual Crossing API (for actual temperature after resolution)
# Get free key at: https://www.visualcrossing.com/
VC_KEY=

# Telegram Bot (for notifications)
# Get token from @BotFather on Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SIGNAL_CHAT_ID=

# Runtime modes
PAPER_MODE=false
LIVE_TRADE=false
SIGNAL_MODE=true

# Groq API (for AI analysis)
# Get free key at: https://console.groq.com/
GROQ_API_KEY=

# Optional: Meteoblue (more weather data)
METEOBLUE_KEY=

# Optional: WeatherBit
WEATHERBIT_KEY=
